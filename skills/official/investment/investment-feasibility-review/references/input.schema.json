{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "투자 타당성 검토 Skill Input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "request": {
      "type": "string",
      "minLength": 1,
      "description": "사용자가 원하는 업무 요청 또는 질문"
    },
    "context": {
      "type": "string",
      "description": "업무 배경, 부서 상황, 보고 대상 등 추가 맥락"
    },
    "attachments_summary": {
      "type": "string",
      "description": "첨부 문서나 표 데이터가 있을 때 핵심 내용 요약"
    },
    "output_format": {
      "type": "string",
      "enum": [
        "brief",
        "memo",
        "report",
        "table"
      ],
      "default": "memo"
    }
  },
  "required": [
    "request"
  ]
}
